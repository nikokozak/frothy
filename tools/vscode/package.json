{
  "name": "frothy",
  "displayName": "Frothy",
  "description": "Live board control for Frothy devices",
  "version": "0.1.0",
  "publisher": "NikolaiKozak",
  "repository": {
    "type": "git",
    "url": "https://github.com/nikokozak/frothy.git"
  },
  "homepage": "https://github.com/nikokozak/frothy",
  "bugs": {
    "url": "https://github.com/nikokozak/frothy/issues"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "files": [
    "out/cli-discovery.js",
    "out/controller.js",
    "out/control-session-client.js",
    "out/extension.js",
    "out/runtime-forms.js",
    "out/send-file.js",
    "out/send-file-reset.js",
    "out/vscode-host.js",
    "syntaxes/**",
    "language-configuration.json",
    "README.md",
    "LICENSE"
  ],
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:frothy"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "frothy",
        "extensions": [
          ".frothy",
          ".froth"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "frothy",
        "scopeName": "source.frothy",
        "path": "./syntaxes/froth.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "frothy.connect",
        "title": "Frothy: Connect Device",
        "icon": "$(plug)"
      },
      {
        "command": "frothy.disconnect",
        "title": "Frothy: Disconnect",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "frothy.sendSelection",
        "title": "Frothy: Send Selection / Form",
        "icon": "$(play)"
      },
      {
        "command": "frothy.runBinding",
        "title": "Frothy: Run Binding",
        "icon": "$(run)"
      },
      {
        "command": "frothy.pinRunBinding",
        "title": "Frothy: Pin Run Binding",
        "icon": "$(pinned)"
      },
      {
        "command": "frothy.runLast",
        "title": "Frothy: Rerun Last Form",
        "icon": "$(debug-rerun)"
      },
      {
        "command": "frothy.runPinned",
        "title": "Frothy: Run Pinned Binding",
        "icon": "$(debug-start)"
      },
      {
        "command": "frothy.sendFile",
        "title": "Frothy: Send File",
        "icon": "$(file-code)"
      },
      {
        "command": "frothy.interrupt",
        "title": "Frothy: Interrupt",
        "icon": "$(debug-stop)"
      },
      {
        "command": "frothy.words",
        "title": "Frothy: Words",
        "icon": "$(list-unordered)"
      },
      {
        "command": "frothy.see",
        "title": "Frothy: See Binding",
        "icon": "$(symbol-field)"
      },
      {
        "command": "frothy.core",
        "title": "Frothy: Show Core Binding",
        "icon": "$(symbol-structure)"
      },
      {
        "command": "frothy.slotInfo",
        "title": "Frothy: Show Slot Info",
        "icon": "$(info)"
      },
      {
        "command": "frothy.save",
        "title": "Frothy: Save Snapshot",
        "icon": "$(save)"
      },
      {
        "command": "frothy.restore",
        "title": "Frothy: Restore Snapshot",
        "icon": "$(history)"
      },
      {
        "command": "frothy.wipe",
        "title": "Frothy: Dangerous Wipe Snapshot",
        "icon": "$(trash)"
      },
      {
        "command": "frothy.doctor",
        "title": "Frothy: Run Doctor",
        "icon": "$(tools)"
      },
      {
        "command": "frothy.showConsole",
        "title": "Frothy: Show Console",
        "icon": "$(terminal)"
      }
    ],
    "keybindings": [
      {
        "command": "frothy.sendSelection",
        "key": "ctrl+enter",
        "mac": "cmd+enter",
        "when": "editorTextFocus && (resourceExtname == .frothy || resourceExtname == .froth)"
      },
      {
        "command": "frothy.runLast",
        "key": "ctrl+alt+r",
        "mac": "cmd+alt+r",
        "when": "frothy.hasLastRun && editorTextFocus && (resourceExtname == .frothy || resourceExtname == .froth)"
      },
      {
        "command": "frothy.pinRunBinding",
        "key": "ctrl+alt+p",
        "mac": "cmd+alt+p",
        "when": "editorTextFocus && (resourceExtname == .frothy || resourceExtname == .froth)"
      },
      {
        "command": "frothy.runPinned",
        "key": "ctrl+alt+enter",
        "mac": "cmd+alt+enter",
        "when": "frothy.hasPinnedRun && editorTextFocus && (resourceExtname == .frothy || resourceExtname == .froth)"
      },
      {
        "command": "frothy.sendFile",
        "key": "ctrl+shift+enter",
        "mac": "cmd+shift+enter",
        "when": "editorTextFocus && (resourceExtname == .frothy || resourceExtname == .froth)"
      },
      {
        "command": "frothy.see",
        "key": "ctrl+alt+b",
        "mac": "cmd+alt+b",
        "when": "editorTextFocus && (resourceExtname == .frothy || resourceExtname == .froth)"
      },
      {
        "command": "frothy.interrupt",
        "key": "ctrl+alt+.",
        "mac": "cmd+alt+.",
        "when": "frothy.isRunning"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "frothy",
          "title": "Frothy",
          "icon": "$(symbol-misc)"
        }
      ]
    },
    "views": {
      "frothy": [
        {
          "id": "frothyDeviceView",
          "name": "Device"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "frothyDeviceView",
        "contents": "Connect to a Frothy device from the current VS Code window.\n\n[Connect Device](command:frothy.connect)\n[Show Console](command:frothy.showConsole)\n[Run Doctor](command:frothy.doctor)"
      }
    ],
    "configuration": {
      "title": "Frothy",
      "properties": {
        "frothy.cliPath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the installed `frothy` CLI binary. Leave empty to auto-discover `frothy` on PATH, fall back to legacy `froth`, or use a repo-local `tools/cli/frothy-cli` build."
        },
        "frothy.port": {
          "type": "string",
          "default": "",
          "description": "Preferred serial port for Frothy device connections. Leave empty to auto-connect one device or prompt when several are found."
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "frothy.connect",
          "when": "view == frothyDeviceView",
          "group": "navigation"
        },
        {
          "command": "frothy.disconnect",
          "when": "view == frothyDeviceView",
          "group": "navigation"
        },
        {
          "command": "frothy.interrupt",
          "when": "view == frothyDeviceView",
          "group": "navigation"
        },
        {
          "command": "frothy.runLast",
          "when": "view == frothyDeviceView && frothy.hasLastRun",
          "group": "navigation"
        },
        {
          "command": "frothy.runPinned",
          "when": "view == frothyDeviceView && frothy.hasPinnedRun",
          "group": "navigation"
        },
        {
          "command": "frothy.pinRunBinding",
          "when": "view == frothyDeviceView",
          "group": "navigation"
        },
        {
          "command": "frothy.showConsole",
          "when": "view == frothyDeviceView",
          "group": "navigation"
        },
        {
          "command": "frothy.words",
          "when": "view == frothyDeviceView",
          "group": "2_actions"
        },
        {
          "command": "frothy.see",
          "when": "view == frothyDeviceView",
          "group": "2_actions"
        },
        {
          "command": "frothy.core",
          "when": "view == frothyDeviceView",
          "group": "2_actions"
        },
        {
          "command": "frothy.slotInfo",
          "when": "view == frothyDeviceView",
          "group": "2_actions"
        },
        {
          "command": "frothy.save",
          "when": "view == frothyDeviceView",
          "group": "2_actions"
        },
        {
          "command": "frothy.restore",
          "when": "view == frothyDeviceView",
          "group": "2_actions"
        },
        {
          "command": "frothy.wipe",
          "when": "view == frothyDeviceView",
          "group": "2_actions"
        },
        {
          "command": "frothy.doctor",
          "when": "view == frothyDeviceView",
          "group": "2_actions"
        }
      ],
      "editor/title": [
        {
          "command": "frothy.sendSelection",
          "when": "resourceExtname == .frothy || resourceExtname == .froth",
          "group": "navigation"
        },
        {
          "command": "frothy.runBinding",
          "when": "resourceExtname == .frothy || resourceExtname == .froth",
          "group": "navigation"
        },
        {
          "command": "frothy.pinRunBinding",
          "when": "resourceExtname == .frothy || resourceExtname == .froth",
          "group": "navigation"
        },
        {
          "command": "frothy.runLast",
          "when": "frothy.hasLastRun && (resourceExtname == .frothy || resourceExtname == .froth)",
          "group": "navigation"
        },
        {
          "command": "frothy.runPinned",
          "when": "frothy.hasPinnedRun && (resourceExtname == .frothy || resourceExtname == .froth)",
          "group": "navigation"
        },
        {
          "command": "frothy.sendFile",
          "when": "resourceExtname == .frothy || resourceExtname == .froth",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "package:vsix": "npm run compile && vsce package --no-yarn",
    "test:package": "npm run compile && node test/package-smoke.js",
    "watch": "tsc -watch -p ./",
    "test:smoke": "node test/control-session-smoke.js && node test/runtime-forms-smoke.js && node test/controller-smoke.js && node test/extension-smoke.js",
    "test:extension-host": "node test/run-extension-host-smoke.js",
    "test": "npm run compile && npm run test:smoke"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "typescript": "^5.3.0"
  }
}
