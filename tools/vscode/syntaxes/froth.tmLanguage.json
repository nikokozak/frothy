{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Frothy",
  "scopeName": "source.frothy",
  "patterns": [
    {
      "include": "#line-comment"
    },
    {
      "include": "#string"
    },
    {
      "include": "#named-code-definition"
    },
    {
      "include": "#function-literal-head"
    },
    {
      "include": "#record-definition"
    },
    {
      "include": "#binding-definition"
    },
    {
      "include": "#loop-binding"
    },
    {
      "include": "#slot-designator"
    },
    {
      "include": "#field-access"
    },
    {
      "include": "#builtin"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#call-target"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#punctuation"
    }
  ],
  "repository": {
    "line-comment": {
      "name": "comment.line.backslash.frothy",
      "match": "(?<!\\S)\\\\.*$"
    },
    "string": {
      "name": "string.quoted.double.frothy",
      "begin": "\"",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.string.begin.frothy"
        }
      },
      "end": "\"",
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.string.end.frothy"
        }
      },
      "patterns": [
        {
          "name": "constant.character.escape.frothy",
          "match": "\\\\(?:[ntr\\\\\"]|x[0-9A-Fa-f]{2})"
        }
      ]
    },
    "named-code-definition": {
      "begin": "(?<![A-Za-z0-9_.!?@])(to)(\\s+)([A-Za-z_][A-Za-z0-9_.!?@]*)",
      "beginCaptures": {
        "1": {
          "name": "keyword.control.definition.frothy"
        },
        "3": {
          "name": "entity.name.function.frothy"
        }
      },
      "end": "(?=\\[|$)",
      "patterns": [
        {
          "name": "keyword.control.parameters.frothy",
          "match": "(?<![A-Za-z0-9_.!?@])(with)(?=\\s)"
        },
        {
          "name": "variable.parameter.frothy",
          "match": "[A-Za-z_][A-Za-z0-9_.!?@]*"
        },
        {
          "name": "punctuation.separator.parameter.frothy",
          "match": ","
        }
      ]
    },
    "function-literal-head": {
      "begin": "(?<![A-Za-z0-9_.!?@])(fn)(?=\\s)",
      "beginCaptures": {
        "1": {
          "name": "storage.type.function.frothy"
        }
      },
      "end": "(?=\\[|$)",
      "patterns": [
        {
          "name": "keyword.control.parameters.frothy",
          "match": "(?<![A-Za-z0-9_.!?@])(with)(?=\\s)"
        },
        {
          "name": "variable.parameter.frothy",
          "match": "[A-Za-z_][A-Za-z0-9_.!?@]*"
        },
        {
          "name": "punctuation.separator.parameter.frothy",
          "match": ","
        }
      ]
    },
    "record-definition": {
      "match": "(?<![A-Za-z0-9_.!?@])(record)(\\s+)([A-Za-z_][A-Za-z0-9_.!?@]*)",
      "captures": {
        "1": {
          "name": "keyword.control.declaration.frothy"
        },
        "3": {
          "name": "entity.name.type.frothy"
        }
      }
    },
    "binding-definition": {
      "match": "(?<![A-Za-z0-9_.!?@])(?:(here)(\\s+))?([A-Za-z_][A-Za-z0-9_.!?@]*)(\\s+)(is)(?=\\s|$)",
      "captures": {
        "1": {
          "name": "keyword.control.declaration.frothy"
        },
        "3": {
          "name": "variable.other.definition.frothy"
        },
        "5": {
          "name": "keyword.control.definition.frothy"
        }
      }
    },
    "loop-binding": {
      "match": "(?<![A-Za-z0-9_.!?@])(as)(\\s+)([A-Za-z_][A-Za-z0-9_.!?@]*)(?=\\s|\\[|$)",
      "captures": {
        "1": {
          "name": "keyword.control.loop.frothy"
        },
        "3": {
          "name": "variable.parameter.frothy"
        }
      }
    },
    "slot-designator": {
      "name": "variable.other.slot-designator.frothy",
      "match": "@[A-Za-z_][A-Za-z0-9_.!?@]*"
    },
    "field-access": {
      "match": "(->)([A-Za-z_][A-Za-z0-9_.!?@]*)",
      "captures": {
        "1": {
          "name": "keyword.operator.field.frothy"
        },
        "2": {
          "name": "variable.other.property.frothy"
        }
      }
    },
    "builtin": {
      "name": "support.function.builtin.frothy",
      "match": "(?<![A-Za-z0-9_.!?@])(?:save|restore|dangerous\\.wipe|words|see|core|slotInfo|cells)(?![A-Za-z0-9_.!?@])"
    },
    "constants": {
      "name": "constant.language.frothy",
      "match": "(?<![A-Za-z0-9_.!?@])(?:true|false|nil)(?![A-Za-z0-9_.!?@])"
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.frothy",
          "match": "(?<![A-Za-z0-9_.!?@])-?0x[0-9A-Fa-f]+(?![A-Za-z0-9_.!?@])"
        },
        {
          "name": "constant.numeric.binary.frothy",
          "match": "(?<![A-Za-z0-9_.!?@])-?0b[01]+(?![A-Za-z0-9_.!?@])"
        },
        {
          "name": "constant.numeric.decimal.frothy",
          "match": "(?<![A-Za-z0-9_.!?@])-?\\d+(?![A-Za-z0-9_.!?@])"
        }
      ]
    },
    "call-target": {
      "name": "support.function.call.frothy",
      "match": "[A-Za-z_][A-Za-z0-9_.!?@]*(?=:)"
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.conditional.frothy",
          "match": "(?<![A-Za-z0-9_.!?@])(?:if|else|when|unless|cond|case)(?![A-Za-z0-9_.!?@])"
        },
        {
          "name": "keyword.control.loop.frothy",
          "match": "(?<![A-Za-z0-9_.!?@])(?:while|repeat)(?![A-Za-z0-9_.!?@])"
        },
        {
          "name": "keyword.control.frothy",
          "match": "(?<![A-Za-z0-9_.!?@])(?:set|call|in|with|here|to|is|record)(?![A-Za-z0-9_.!?@])"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.word.frothy",
          "match": "(?<![A-Za-z0-9_.!?@])(?:and|or|not)(?![A-Za-z0-9_.!?@])"
        },
        {
          "name": "keyword.operator.symbol.frothy",
          "match": "==|!=|<=|>=|[-+*/%<>]"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.section.group.begin.frothy",
          "match": "\\("
        },
        {
          "name": "punctuation.section.group.end.frothy",
          "match": "\\)"
        },
        {
          "name": "punctuation.section.block.begin.frothy",
          "match": "\\["
        },
        {
          "name": "punctuation.section.block.end.frothy",
          "match": "\\]"
        },
        {
          "name": "punctuation.separator.arguments.frothy",
          "match": ","
        },
        {
          "name": "punctuation.separator.statement.frothy",
          "match": ";"
        },
        {
          "name": "punctuation.separator.call.frothy",
          "match": ":"
        }
      ]
    }
  }
}
