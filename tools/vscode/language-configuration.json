{
  "comments": {
    "lineComment": "\\"
  },
  "brackets": [
    [
      "(",
      ")"
    ],
    [
      "[",
      "]"
    ]
  ],
  "autoClosingPairs": [
    {
      "open": "\"",
      "close": "\"",
      "notIn": [
        "string",
        "comment"
      ]
    },
    {
      "open": "(",
      "close": ")",
      "notIn": [
        "string",
        "comment"
      ]
    },
    {
      "open": "[",
      "close": "]",
      "notIn": [
        "string",
        "comment"
      ]
    }
  ],
  "surroundingPairs": [
    [
      "\"",
      "\""
    ],
    [
      "(",
      ")"
    ],
    [
      "[",
      "]"
    ]
  ],
  "wordPattern": "(@?[A-Za-z_][A-Za-z0-9_.!?@]*)|(-?(?:0x[0-9A-Fa-f]+|0b[01]+|\\d+))",
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(?!\\\\)(?:(?=.*\\[(?!.*\\]))|(?=.*\\((?!.*\\)))|.*(?:\\b(?:is|to|as)\\b|:)\\s*)$",
    "decreaseIndentPattern": "^\\s*[\\]\\)].*$"
  },
  "onEnterRules": [
    {
      "beforeText": "^\\s*(?!\\\\).*(?:\\[(?!.*\\])|\\((?!.*\\)))\\s*$",
      "afterText": "^\\s*[\\]\\)]",
      "action": {
        "indent": "indentOutdent"
      }
    },
    {
      "beforeText": "^\\s*(?!\\\\).*(?:\\[(?!.*\\])|\\((?!.*\\))|(?:\\b(?:is|to|as)\\b|:)\\s*)$",
      "action": {
        "indent": "indent"
      }
    }
  ]
}
