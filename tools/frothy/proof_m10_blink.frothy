period is 50
pulses is 3
to led.on with pin [ gpio.write: pin, 1 ]
to led.off with pin [ gpio.write: pin, 0 ]
to pulse with pin, wait [
  led.on: pin
  ms: wait
  led.off: pin
]
to blink with pin, count, wait [
  gpio.mode: pin, 1
  repeat count as i [
    pulse: pin, wait
    ms: wait
  ]
]
blink: LED_BUILTIN, pulses, period
