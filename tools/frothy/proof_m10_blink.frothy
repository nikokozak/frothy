period = 50
pulses = 3
led.on = fn(pin) { gpio.write(pin, 1) }
led.off = fn(pin) { gpio.write(pin, 0) }
pulse = fn(pin, wait) {
  led.on(pin)
  ms(wait)
  led.off(pin)
}
blink = fn(pin, count, wait) {
  i = 0
  gpio.mode(pin, 1)
  while i < count {
    pulse(pin, wait)
    ms(wait)
    set i = i + 1
  }
}
blink(LED_BUILTIN, pulses, period)
